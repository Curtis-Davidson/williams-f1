    # PURPOSE: Configure GPO to allow RDP login only for the RDP-WF1LT-M3079 group via SID injection
    -----------------------------------


    # Define GPO name and target group SID
    $gpoName = "RDP Access – WF1LT-M3079"
    $rdpGroupSID = (Get-ADGroup -Identity "RDP-WF1LT-M3079").SID.Value

    # Create GPO (if not already existing)
