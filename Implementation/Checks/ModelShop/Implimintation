# Create modelshop access control groups
New-ADGroup -Name "grp-modelshopLAC" -GroupScope Global -GroupCategory Security -Path "OU=Groups,DC=corp,DC=williamsf1,DC=com"
New-ADGroup -Name "grp-modelshopRDC" -GroupScope Global -GroupCategory Security -Path "OU=Groups,DC=corp,DC=williamsf1,DC=com"

# Add shared account to Login Access Control group
Add-ADGroupMember -Identity "grp-modelshopLAC" -Members "shr-modelshop"

