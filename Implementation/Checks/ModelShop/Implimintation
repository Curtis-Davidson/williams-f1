    Set-GPRegistryValue -Name $gpoName `
        -Key "HKLM\Software\Microsoft\Windows NT\CurrentVersion\Winlogon\SpecialAccounts\UserList" `
        -ValueName "SeRemoteInteractiveLogonRight" `
        -Type MultiString `
        -Value "*$rdpGroupSID"



