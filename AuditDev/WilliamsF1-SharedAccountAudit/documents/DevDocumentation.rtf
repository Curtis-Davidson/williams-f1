# =============================================\
# Williams F1 Full AD Discovery & Intelligence Audit\
# File: williamsf1-ad-audit.ps1\
# Author: Curtis-Davidson & G (Williams Trusted Infra)\
# Version: 2025.6.4\
# =============================================\
\
# === IMPORT CONFIG & MODULES ===\
Import-Module ActiveDirectory -ErrorAction Stop\
. "$PSScriptRoot\\..\\config\\audit-config.ps1"\
. "$PSScriptRoot\\..\\lib\\core-functions.ps1"\
\
Write-Host "`n[INFO] Starting FULL AD DISCOVERY..." -ForegroundColor Green\
\
# === ENSURE OUTPUT DIRECTORY EXISTS ===\
if (!(Test-Path $OutDir)) \{\
    New-Item -ItemType Directory -Path $OutDir -Force | Out-Null\
\}\
\
# === INITIALISE OUTPUTS ===\
"Username,DisplayName,OU,Enabled,LastLogon,Groups,GPOs,MappedDrives,ExchangeBindings" | Out-File $csvOut -Encoding UTF8\
\
@"\
# Full AD Discovery \'96 Williams F1\
**Generated:** $ts\
| Username | DisplayName | OU | Enabled | LastLogon | Groups | GPOs | Drives | Mailbox |\
|----------|-------------|----|---------|-----------|--------|------|--------|---------|\
"@ | Out-File $mdOut -Encoding UTF8\
\
$htmlHeader = @"\
<!DOCTYPE html><html><head>\
<title>Full AD Discovery \'96 Williams F1</title>\
<style>\
body \{ font-family: Segoe UI, sans-serif; background: white; color: black; \}\
table \{ width: 100%; border-collapse: collapse; margin-top: 12px; \}\
th, td \{ border: 1px solid #ccc; padding: 8px; \}\
th \{ background: #003366; color: white; \}\
tr:nth-child(even) \{ background-color: #f9f9f9; \}\
</style></head><body>\
<h1>Full AD Discovery \'96 Williams F1</h1>\
<p><b>Generated:</b> $ts</p>\
<table>\
<tr><th>Username</th><th>DisplayName</th><th>OU</th><th>Enabled</th><th>LastLogon</th><th>Groups</th><th>GPOs</th><th>Drives</th><th>Mailbox</th></tr>\
"@\
$htmlHeader | Out-File $htmlOut -Encoding UTF8\
\
$jsonData = @()\
\
# === ENUMERATE USERS ===\
$users = Get-AllUsers\
\
foreach ($u in $users) \{\
    $ou        = Get-OUPath $u.DistinguishedName\
    $groups    = Describe-Group $u\
    $gpos      = Get-GPOsForUser $u\
    $drives    = Get-MappedDrives $u\
    $mailbox   = Get-ExchangeBindings $u\
\
    # CSV Output\
    "$($u.SamAccountName),$($u.DisplayName),$ou,$($u.Enabled),$($u.LastLogonDate),""$groups"",""$gpos"",""$drives"",""$mailbox""" |\
        Out-File $csvOut -Append -Encoding UTF8\
\
    # Markdown Output\
    "| $($u.SamAccountName) | $($u.DisplayName) | $ou | $($u.Enabled) | $($u.LastLogonDate) | `$groups` | `$gpos` | `$drives` | `$mailbox` |" |\
        Out-File $mdOut -Append -Encoding UTF8\
\
    # HTML Output\
    "<tr><td>$($u.SamAccountName)</td><td>$($u.DisplayName)</td><td>$ou</td><td>$($u.Enabled)</td><td>$($u.LastLogonDate)</td><td>$groups</td><td>$gpos</td><td>$drives</td><td>$mailbox</td></tr>" |\
        Out-File $htmlOut -Append -Encoding UTF8\
\
    # JSON Structure\
    $jsonData += [PSCustomObject]@\{\
        Username  = $u.SamAccountName\
        Display   = $u.DisplayName\
        OU        = $ou\
        Enabled   = $u.Enabled\
        LastLogon = $u.LastLogonDate\
        Groups    = $groups\
        GPOs      = $gpos\
        Drives    = $drives\
        Mailbox   = $mailbox\
    \}\
\}\
\
# === FINALISE HTML ===\
"</table></body></html>" | Out-File $htmlOut -Append -Encoding UTF8\
\
# === WRITE JSON ===\
$jsonData | ConvertTo-Json -Depth 5 | Out-File $jsonOut -Encoding UTF8\
\
# === DONE ===\
Write-Host "`n [COMPLETE] AD Discovery Report Generated"\
Write-Host " CSV     : $csvOut"\
Write-Host " Markdown: $mdOut"\
Write-Host " HTML    : $htmlOut"\
Write-Host " JSON    : $jsonOut"\
Write-Host " Log     : $log"\
"@\
