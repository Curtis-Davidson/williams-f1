# =============================================\
# Williams F1 Shared Account Audit - Core Functions\
# Author: Curtis-Davidson & G\
# Version: 2025.6.4\
# =============================================\
\
# --- PURPOSE ---\
# Reusable discovery functions for users, groups, permissions, GPOs, Exchange bindings, mapped drives.\
\
# === Get all AD users (enabled only) ===\
function Get-AllUsers \{\
    # Retrieves all enabled AD users with full properties\
    Get-ADUser -Filter * -Properties * | Where-Object \{ $_.Enabled -eq $true \}\
\}\
\
# === Get all AD groups (security only) ===\
function Get-AllGroups \{\
    # Retrieves all security-enabled AD groups with members\
    Get-ADGroup -Filter 'GroupScope -like "*"' -Properties Members\
\}\
\
# === Return simplified OU path ===\
function Get-OUPath \{\
    param([string]$distinguishedName)\
    ($distinguishedName -split ',(?=OU=)') -join '\\'\
\}\
\
# === Enumerate nested group memberships ===\
function Get-NestedGroups \{\
    param([string]$groupDn)\
    try \{\
        $nested = Get-ADGroupMember -Identity $groupDn -Recursive | Where-Object \{ $_.objectClass -eq 'group' \}\
        return $nested.Name\
    \} catch \{\
        return @()\
    \}\
\}\
\
# === Describe AD group by name ===\
function Describe-Group \{\
    param([string]$groupName)\
    try \{\
        $group = Get-ADGroup $groupName -Properties Description\
        return "$groupName: $($group.Description)"\
    \} catch \{\
        return "$groupName: [NO DESCRIPTION]"\
    \}\
\}\
\
# === Get applied GPOs for group ===\
function Get-GPOsForGroup \{\
    param([string[]]$groupNames)\
    $linkedGPOs = @()\
    foreach ($g in $groupNames) \{\
        try \{\
            $gpoLinks = Get-GPO -All | Where-Object \{ $_.DisplayName -like "*$g*" \}\
            $linkedGPOs += $gpoLinks.DisplayName\
        \} catch \{\}\
    \}\
    return $linkedGPOs | Sort-Object -Unique\
\}\
\
# === Lookup NTFS Permissions (ACLs) for each user on known shares ===\
function Get-ACLsForUser \{\
    param([string]$username)\
    $acls = @()\
    foreach ($path in $script:knownShares) \{\
        try \{\
            $acl = Get-Acl $path\
            foreach ($ace in $acl.Access) \{\
                if ($ace.IdentityReference -match $username) \{\
                    $acls += "$path : $($ace.FileSystemRights)"\
                \}\
            \}\
        \} catch \{\}\
    \}\
    return $acls\
\}\
\
# === Get mapped drives and login scripts from user attributes ===\
function Get-LoginScriptsAndMappedDrives \{\
    param([Microsoft.ActiveDirectory.Management.ADUser]$user)\
    $scripts = @()\
    if ($user.ScriptPath) \{\
        $scripts += "LoginScript: $($user.ScriptPath)"\
    \}\
    return $scripts\
\}\
\
# === Get Exchange Shared Mailboxes Bound to Account ===\
function Get-ExchangeMailboxBinding \{\
    param([string]$username)\
    try \{\
        $mailboxes = Get-MailboxPermission -Identity $username -ErrorAction SilentlyContinue | Where-Object \{\
            $_.User -notlike 'NT AUTHORITY*' -and $_.AccessRights -contains "FullAccess"\
        \}\
        return $mailboxes.User\
    \} catch \{\
        return @("[Exchange not available or permission denied]")\
    \}\
\}\
